# e2e テスト用の共通設定。{{LLM_URL}} はシナリオ実行時にモックLLMサーバーのURLへ展開される。
llm:
  provider: openai
  temperature: 0.7
  max_retries: 1
  min_request_interval_ms: 0
  openai:
    base_url: {{LLM_URL}}
    api_key_env: TEST_LLM_API_KEY
    model: e2e-test-model

voicevox:
  # 実際の接続先は環境変数 VOX_RADIO_VOICEVOX_URL（モックVOICEVOXのURL）で上書きされる。
  url: http://localhost:50021

cache:
  max_entries: 100
  retention_days: 90
  llm_context_entries: 10

slack:
  bot_token_env: TEST_SLACK_BOT_TOKEN

characters:
  zundamon:
    name: ずんだもん
    pronoun: ボク
    speech_suffix: ["〜のだ", "〜なのだ"]
    personality: ["元気", "明るい"]
    default_style: ノーマル
    styles:
      ノーマル: 3
  metan:
    name: 四国めたん
    pronoun: わたくし
    speech_suffix: ["〜ですわ", "〜かしら"]
    personality: ["お嬢様", "しっかり者"]
    default_style: ノーマル
    styles:
      ノーマル: 2
