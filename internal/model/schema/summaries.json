{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Summaries",
  "type": "object",
  "required": ["summaries"],
  "properties": {
    "summaries": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/Summary"
      }
    }
  },
  "$defs": {
    "Summary": {
      "type": "object",
      "required": ["url", "points"],
      "properties": {
        "url":     { "type": "string", "format": "uri" },
        "points": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1
        }
      },
      "additionalProperties": false
    }
  }
}
