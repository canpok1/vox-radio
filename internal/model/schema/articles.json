{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Articles",
  "type": "object",
  "required": ["articles"],
  "properties": {
    "articles": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/Article"
      }
    }
  },
  "$defs": {
    "Article": {
      "type": "object",
      "required": ["title"],
      "properties": {
        "url":         { "type": "string", "format": "uri" },
        "title":       { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1, "description": "フィード由来のテキスト（RSS/Atom content/description）" },
        "body":        { "type": "string", "minLength": 1, "description": "記事ページ直接取得のテキスト（fetchArticle）" }
      },
      "additionalProperties": false
    }
  }
}
